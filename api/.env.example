# Backend server
PORT_NUM=5000

# Flask model service
ML_SERVICE_BASE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT_MS=15000

# Local LLM explanations for driver quiz results
# Uses free local inference only. Switch to llama3.1:8b if your hardware allows it.
LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=60

# Authentication
JWT_ACCESSTOKEN=replace_with_a_long_random_secret
# Google Sign-In: list every OAuth Web client ID that may issue ID tokens we accept
# (web app + each mobile app). Android client IDs are NOT audiences — leave them out.
# Prefer GOOGLE_CLIENT_IDS (comma-separated). GOOGLE_WEB_CLIENT_ID /
# GOOGLE_MOBILE_WEB_CLIENT_ID and the legacy single GOOGLE_CLIENT_ID are also honored.
GOOGLE_CLIENT_ID=426680744492-pesf948u29q064s9t4anvqo513pidii8.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=426680744492-pesf948u29q064s9t4anvqo513pidii8.apps.googleusercontent.com
GOOGLE_MOBILE_WEB_CLIENT_ID=944652922057-2brrr9smor8hn2l1sct50slqqe1qiref.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=426680744492-pesf948u29q064s9t4anvqo513pidii8.apps.googleusercontent.com,944652922057-2brrr9smor8hn2l1sct50slqqe1qiref.apps.googleusercontent.com

# PostgreSQL database connection settings
PGHOST=localhost
PGPORT=5432
PGUSER=siara_admin
PGPASSWORD=replace_with_db_password
PGDATABASE=siara
# PGSSLMODE=require

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email delivery
EMAIL_PROVIDER=smtp
EMAIL_PREVIEW=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM_ADDRESS=your_gmail_address@gmail.com
EMAIL_FROM_NAME=SIARA
