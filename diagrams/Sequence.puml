@startuml

actor "Citizen User" as User
participant "Web Frontend" as Frontend
participant "Incident API" as Backend
database "Database" as DB
participant "Context Data API" as ContextAPI
participant "AI Prediction Engine" as AI
participant "Alert Service" as Alert
participant "Notification Service" as Notify
participant "Map Service" as MapAPI

User -> Frontend : Open "Report Incident" form
Frontend -> User : Display reporting interface

User -> Frontend : Submit incident data\n(location, description, media)

Frontend -> Backend : POST /incidents
activate Backend

' Store only user-submitted data
Backend -> DB : Create Incident (raw data)
DB --> Backend : Incident stored

' Get external context (NOT stored)
Backend -> ContextAPI : Fetch context data\n(weather, road, traffic)
ContextAPI --> Backend : Context data

' AI uses context directly (no DB access)
Backend -> AI : Analyze incident + context
activate AI
AI -> AI : Compute risk score
AI --> Backend : RiskPrediction
deactivate AI

' Update incident with risk only
Backend -> DB : Update Incident\n(status="reported", riskScore)

Backend -> Alert : Evaluate alert conditions
activate Alert

Alert -> DB : Check alert subscriptions
DB --> Alert : Matching users/zones

Alert -> Notify : Send alert notifications
activate Notify
Notify -> DB : Store notifications
Notify --> User : Push notification
deactivate Notify
deactivate Alert

Backend -> MapAPI : Update map markers
MapAPI --> Backend : Map updated

Backend --> Frontend : Incident created successfully
deactivate Backend

Frontend -> User : Display confirmation\nand incident on map

@enduml