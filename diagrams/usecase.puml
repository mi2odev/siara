UC3 --> UC22 : <<include>>
UC22 --> UC23 : <<include>>
UC23 --> UC24 : <<include>>

UC9 --> UC25 : <<include>>

UC10 --> UC4 : <<include>>
UC11 --> UC12 : <<include>>
UC15 --> UC16 : <<include>>

@enduml