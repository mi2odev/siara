VITE_API_BASE_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=426680744492-pesf948u29q064s9t4anvqo513pidii8.apps.googleusercontent.com

# Fallback test location used when the browser/GPS cannot return a fix.
# Defaults: 36.7538, 3.0588 (downtown Algiers). Override per environment if
# QA needs to point the fallback elsewhere.
# VITE_FALLBACK_LAT=36.7538
# VITE_FALLBACK_LNG=3.0588
# VITE_FALLBACK_LOCATION_LABEL=Fallback test location - Algiers

# When set to "true", a police officer's fallback location is also uploaded
# to the backend (tagged source="fallback_test"). Leave unset in production —
# fallback positions must never be treated as a trusted GPS fix.
# VITE_ALLOW_FALLBACK_LOCATION_UPLOAD=false